# ============================================================
# Smart Pick Pro — Secrets Configuration
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .streamlit/secrets.toml:
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Replace the placeholder values below with your real keys.
#   3. Restart the app (streamlit run Smart_Picks_Pro_Home.py).
#
# IMPORTANT:
#   - .streamlit/secrets.toml is in .gitignore — it will NEVER be
#     committed to version control. Your keys stay private.
#   - You can also enter keys in the ⚙️ Settings page at runtime,
#     or set them as environment variables.
#
# WHERE TO GET KEYS:
#   Stripe                      → https://dashboard.stripe.com/developers
# ============================================================

# ── Required for DraftKings Pick6 data ────────────────────────
ODDS_API_KEY = "your_the_odds_api_key"                 # https://the-odds-api.com/

# ── Required for Stripe payments ─────────────────────────────
STRIPE_SECRET_KEY = "sk_live_..."                      # Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY = "pk_live_..."
STRIPE_PRICE_ID = "price_..."                          # Stripe Dashboard → Products
STRIPE_WEBHOOK_SECRET = "whsec_..."                    # Stripe Dashboard → Webhooks (optional but recommended)

# ── Required for production mode ─────────────────────────────
# MUST be "true" to enforce subscription gates in live deployments.
# When absent or not "true", all premium features are unlocked (dev mode).
SMARTAI_PRODUCTION = "true"
APP_URL = "https://your-app.streamlit.app"             # Your deployed app URL (no trailing slash)

# ── Optional ─────────────────────────────────────────────────
DB_PATH = "db/smartai_nba.db"                          # Override default SQLite path
LOG_LEVEL = "INFO"                                     # DEBUG, INFO, WARNING, ERROR
