# Python cache files — generated automatically, don't commit
__pycache__/
*.py[cod]
*$py.class
*.pyc

# SQLite database — created automatically on first run, don't commit
db/*.db
# Keep the .gitkeep placeholder
!db/.gitkeep

# Runtime data files — generated by live data fetches, don't commit
data/injury_status.json
data/game_logs_cache.json
data/game_logs/
tracking/clv_log.json
tracking/line_movement.json
tracking/joseph_diary.json

# Pipeline-generated data files — runtime artifacts, only .gitkeep is tracked
data/raw/*.parquet
data/raw/*.csv
data/raw/*.json
data/processed/*.parquet
data/processed/*.csv
data/processed/*.json
data/ml_ready/*.parquet
data/ml_ready/*.csv
data/ml_ready/*.json
# Keep the .gitkeep placeholders
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/ml_ready/.gitkeep

# Saved ML model artifacts — large binary files, don't commit
engine/models/saved/*.joblib
engine/models/saved/*.pkl
# Keep the .gitkeep placeholder
!engine/models/saved/.gitkeep

# Log files — generated at runtime, don't commit
logs/
*.log
logs/*.log
logs/*.log.*

# File-based cache — generated at runtime by utils.cache.FileCache
cache/

# Environment / secrets — NEVER commit API keys or credentials
.env
.env.*
!.env.example
secrets.toml
.streamlit/secrets.toml

# Virtual environment (if user creates one)
venv/
.venv/
env/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
.pytest_cache/
catboost_info/
