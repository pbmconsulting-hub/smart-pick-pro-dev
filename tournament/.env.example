# Tournament System Environment (Copy to .env and fill in)

# Database
DATABASE_URL=sqlite:///tournament.db
# DATABASE_URL=postgresql://user:password@localhost:5432/tournament

# Stripe (for Phase 2+)
STRIPE_API_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_LEGEND_PASS_PRICE_ID=price_legend_pass_...
STRIPE_PREMIUM_PRICE_ID=price_premium_...
TOURNAMENT_STRIPE_WEBHOOK_SECRET=whsec_...

# Parent App (for imports)
PARENT_APP_ROOT=../

# Logging
DEBUG=False
LOG_LEVEL=INFO

# Geo-blocking (future)
ALLOWED_STATES=all  # or comma-sep list
BLOCKED_STATES=WA,ID,MT,HI,NV
